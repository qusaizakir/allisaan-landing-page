---
const { id } = Astro.params;

const packageName = "com.qzakapps.lisandictionary";
const playStoreUrl = `https://play.google.com/store/apps/details?id=${packageName}`;

// Chrome/Android best-effort open + fallback
const intentUrl =
  `intent://allisaan.uk/word/${id}` +
  `#Intent;scheme=https;package=${packageName};` +
  `S.browser_fallback_url=${encodeURIComponent(playStoreUrl)};end`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Redirecting…</title>
  </head>
  <body>
    <script is:inline>
      const intentUrl = {JSON.stringify(intentUrl)};
      const playStoreUrl = {JSON.stringify(playStoreUrl)};

      // Try open app (Chrome supports intent://)
      window.location.replace(intentUrl);

      // Browsers that ignore intent:// (e.g. Firefox) will stay here -> send to Play
      setTimeout(() => window.location.replace(playStoreUrl), 1200);
    </script>
  </body>
</html>
