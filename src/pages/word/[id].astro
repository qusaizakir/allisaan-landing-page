---
export const prerender = false;

const { id } = Astro.params;
const pkg = "com.qzakapps.lisandictionary";

// Optional: pass the word id through Play Install Referrer
const referrer = encodeURIComponent(`word_id=${id}`);
const play = `https://play.google.com/store/apps/details?id=${pkg}&referrer=${referrer}`;

return Astro.redirect(play, 302);
---
