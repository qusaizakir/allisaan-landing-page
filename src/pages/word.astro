---
const packageName = "com.qzakapps.lisandictionary";
const playStoreUrl = `https://play.google.com/store/apps/details?id=${packageName}`;
---

<html>
  <head><meta charset="utf-8" /></head>
  <body>
    <script is:inline>
      const packageName = "com.qzakapps.lisandictionary";
      const playStoreUrl = "https://play.google.com/store/apps/details?id=" + packageName;

      // pathname will still be /word/500 because of the 200 rewrite
      const path = window.location.pathname; // e.g. "/word/500"
      const rest = path.replace(/^\/word\/?/, ""); // "500"
      const id = rest.split("/")[0];              // "500" (handles "/word/500/")

      if (!id) {
        // nothing to deep link
        window.location.replace(playStoreUrl);
      } else {
        const encodedId = encodeURIComponent(id);

        const intentUrl =
          "intent://allisaan.uk/word/" + encodedId +
          "#Intent;scheme=https;package=" + packageName + ";" +
          "S.browser_fallback_url=" + encodeURIComponent(playStoreUrl) + ";end";

        window.location.replace(intentUrl);
        setTimeout(() => window.location.replace(playStoreUrl), 1200);
      }
    </script>
  </body>
</html>
